# Polymarket Bot Configuration
# Copy to .env and fill in values

# Required: Polygon wallet private key (with 0x prefix)
PRIVATE_KEY=

# Required: Funder/wallet address (0x + 40 hex chars)
FUNDER_ADDRESS=

# Signature type: 0=EOA, 1=Magic, 2=Proxy
SIGNATURE_TYPE=0

# Safety: 1=simulate only, 0=live trading
DRY_RUN=1

# Polygon RPC (HTTP) - paid Alchemy recommended for larger block queries
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polygon WebSocket (WSS) - required for real-time Settle event detection
# Defaults to converting POLYGON_RPC_URL from https:// to wss://
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Trading parameters
MAX_ORDER_SIZE=5.0
MIN_EDGE=0.02

# Telegram notifications (optional)
# 1. Create bot via @BotFather, get token
# 2. Send a message to the bot, then get chat_id from:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
