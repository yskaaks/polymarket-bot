# Polymarket Bot Configuration
# Copy to .env and fill in values

# Required: Polygon wallet private key (with 0x prefix)
PRIVATE_KEY=

# Required: Funder/wallet address (0x + 40 hex chars)
FUNDER_ADDRESS=

# Signature type: 0=EOA, 1=Magic, 2=Proxy
SIGNATURE_TYPE=0

# Safety: 1=simulate only, 0=live trading
DRY_RUN=1

# Polygon RPC (HTTP) - paid Alchemy recommended for larger block queries
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polygon WebSocket (WSS) - required for real-time Settle event detection
# Defaults to converting POLYGON_RPC_URL from https:// to wss://
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Trading parameters
MAX_ORDER_SIZE=5.0
MIN_EDGE=0.02

# Telegram notifications (optional)
# 1. Create bot via @BotFather, get token
# 2. Send a message to the bot, then get chat_id from:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market-making strategy settings
MM_MAX_MARKETS=5                    # Max concurrent markets to quote
MM_MAX_POSITION_PER_MARKET=2000     # Max USDC exposure per market
MM_MAX_TOTAL_EXPOSURE=20000         # Max total USDC exposure across all markets
MM_MIN_SPREAD=0.03                  # Min spread to consider (3%)
MM_MAX_SPREAD=0.20                  # Max spread to consider (20%)
MM_MIN_LIQUIDITY=5000               # Min market liquidity ($)
MM_MIN_VOLUME_24H=2000              # Min 24h volume ($)
MM_QUOTE_REFRESH=10                 # Quote refresh interval (seconds)
MM_CAPITAL=100000                   # Total capital allocated to MM ($)
MM_STOP_LOSS_PER_MARKET=-200        # Per-market stop loss ($, negative)
